{
  "gateway": {
    "mode": "local"
  },
  "models": {
    "providers": {
      "llamacpp-local": {
        "baseUrl": "http://llamacpp-server:8080/v1",
        "apiKey": "sk-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "local-model",
            "name": "Local llama.cpp Model",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 },
            "contextWindow": 8192,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "llamacpp-local/local-model"
      },
      "timeoutSeconds": 300
    }
  }
}
